generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionTier {
  FREE
  PLUS
  BUSINESS
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id                String           @id @default(cuid())
  name              String?
  nickname          String?
  email             String?          @unique
  emailVerified     DateTime?
  image             String?
  socialLinksJson   String?
  lemonCustomerId   String?
  lemonSubscriptionId String?
  lemonSubscriptionStatus String?
  lemonCustomerPortalUrl String? @db.Text
  currentLanguage   String           @default("ar")
  activeTier        SubscriptionTier @default(FREE)
  tokenBalance      Int              @default(3)
  role              UserRole         @default(USER)
  firstEmailDomain  String?
  registrationRegion String?
  referralSource    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  accounts          Account[]
  sessions          Session[]
  transactions      Transaction[]
  capsules          MomentCapsule[]
  visitorLogs       VisitorLog[]
  interactionEvents InteractionEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VisitorLog {
  id               String   @id @default(cuid())
  userId           String?
  ipAddress        String
  geographicRegion String
  userAgent        String
  referralSource   String?
  timestamp        DateTime @default(now())
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([geographicRegion, timestamp])
  @@index([userId, timestamp])
}

model InteractionEvent {
  id               String   @id @default(cuid())
  userId           String?
  eventType        String
  metadataJson     String?
  geographicRegion String
  createdAt        DateTime @default(now())
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([geographicRegion, createdAt])
  @@index([userId, createdAt])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  stripeSessionId String   @unique
  amountPaid      Int
  currency        String
  status          String
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MomentCapsule {
  id               String   @id @default(cuid())
  userId           String
  title            String
  language         String
  templateJson     String
  fulfillmentPartner String @default("printful")
  fulfillmentStatus  String @default("DRAFT")
  stripeSessionId  String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
