generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id
  premiumTokens Int           @default(3)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactions  Transaction[]
  capsules      MomentCapsule[]
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  stripeSessionId String   @unique
  amountPaid      Int
  currency        String
  status          String
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MomentCapsule {
  id               String   @id @default(cuid())
  userId           String
  title            String
  language         String
  templateJson     String
  fulfillmentPartner String @default("printful")
  fulfillmentStatus  String @default("DRAFT")
  stripeSessionId  String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
